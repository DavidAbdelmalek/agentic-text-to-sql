{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "comment_allow": "Convenience allowlist so the build iterates without constant prompts. NOTE: the real DB safety boundary is the read-only Postgres role (see docs/DECISIONS.md), NOT these strings — a command allowlist cannot reliably parse SQL intent.",
    "allow": [
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(poetry:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(python -m:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(dbt:*)",
      "Bash(make:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker exec:*)",
      "Bash(psql:*)",
      "Bash(pg_isready:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git commit:*)",
      "PowerShell(uv:*)",
      "PowerShell(uvx:*)",
      "PowerShell(python:*)",
      "PowerShell(pytest:*)",
      "PowerShell(ruff:*)",
      "PowerShell(mypy:*)",
      "PowerShell(dbt:*)",
      "PowerShell(docker compose:*)",
      "PowerShell(docker ps:*)",
      "PowerShell(docker logs:*)",
      "PowerShell(psql:*)",
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Edit(./dbt/**)",
      "Edit(./docs/**)",
      "Edit(./.github/**)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:files.pythonhosted.org)",
      "WebFetch(domain:hub.docker.com)"
    ],
    "comment_deny": "Hard stops. Destructive shell, DB write-paths as defense-in-depth, secret files, force-push, sudo. deny ALWAYS overrides allow.",
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(dropdb:*)",
      "Bash(createdb:*)",
      "Bash(psql:*DROP *)",
      "Bash(psql:*DELETE *)",
      "Bash(psql:*TRUNCATE *)",
      "Bash(psql:*UPDATE *)",
      "Bash(psql:*INSERT *)",
      "Bash(psql:*ALTER *)",
      "PowerShell(Remove-Item -Recurse*)",
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./secrets/**)"
    ],
    "comment_ask": "Out-of-scope but occasionally needed — prompt the human instead of silently allowing/denying.",
    "ask": [
      "Bash(git push:*)",
      "Bash(docker compose down:*)"
    ]
  },
  "enableAllProjectMcpServers": false
}
