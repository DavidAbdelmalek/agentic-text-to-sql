# ---------------------------------------------------------------------------
# Copy to .env and fill in. .env is gitignored and MUST NOT be committed.
# Defaults below run the whole stack LOCALLY and FREE (no API keys required):
# the eval falls back to deterministic mock mode when no LLM key is present.
# ---------------------------------------------------------------------------

# --- Postgres (docker-compose) ---------------------------------------------
POSTGRES_DB=warehouse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Superuser role — used ONLY by docker init + dbt build (DDL/DML). Never by the agent.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres

# Read-only role — the ONLY credentials the agent ever uses. SELECT + EXPLAIN only.
AGENT_DB_USER=agent_ro
AGENT_DB_PASSWORD=agent_ro_pw

# Full DSN the agent connects with (read-only role). Keep this read-only.
AGENT_DATABASE_URL=postgresql://agent_ro:agent_ro_pw@localhost:5432/warehouse

# --- LLM provider ----------------------------------------------------------
# LLM_PROVIDER: ollama (default, local/free) | anthropic | openai | azure | mock
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5-coder:7b
# Local Ollama endpoint (the only non-localhost-allowed exception is the configured cloud LLM below)
OLLAMA_BASE_URL=http://localhost:11434

# --- Anthropic Claude (cloud) ---
# A claude.ai SUBSCRIPTION is NOT an API key. Get a key at console.anthropic.com (starter
# credits included), then set:  LLM_PROVIDER=anthropic  LLM_MODEL=claude-opus-4-8
# (cheaper options: claude-sonnet-4-6, claude-haiku-4-5)
ANTHROPIC_API_KEY=

# Cloud LLM (optional). If set, LLM_PROVIDER must be openai/azure.
OPENAI_API_KEY=
OPENAI_BASE_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# --- Embeddings (schema retrieval over pgvector) ---------------------------
# EMBED_PROVIDER: local (sentence-transformers, free) | openai | azure
EMBED_PROVIDER=local
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Langfuse (tracing + eval). Optional; tracing is a no-op if keys unset. -
# These defaults match the keys seeded by the compose `observability` profile, so
# `docker compose --profile observability up -d` + these values = working traces.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local-ttsql
LANGFUSE_SECRET_KEY=sk-lf-local-ttsql

# --- Agent guardrail tunables ----------------------------------------------
SQL_MAX_REPAIR_RETRIES=2
SQL_DEFAULT_ROW_LIMIT=1000
SQL_STATEMENT_TIMEOUT_MS=5000
