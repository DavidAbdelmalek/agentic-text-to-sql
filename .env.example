# ---------------------------------------------------------------------------
# Copy to .env and fill in. .env is gitignored and MUST NOT be committed.
#
# Two ways to run:
#  - LLM_PROVIDER=mock   -> runs the whole graph OFFLINE (no warehouse, no key). CI/test path.
#  - LLM_PROVIDER=cortex -> real run: in-warehouse Snowflake Cortex LLM + read-only AGENT_RO role.
# ---------------------------------------------------------------------------

# --- LLM provider ----------------------------------------------------------
# cortex (in-warehouse, real) | mock (offline, deterministic). No external/cloud providers.
LLM_PROVIDER=cortex
# Snowflake Cortex model id, called via AI_COMPLETE with temperature 0 (deterministic SQL).
# mistral-large2 is in-region (EU). Claude etc. are reachable via cross-region inference.
CORTEX_MODEL=mistral-large2

# --- Snowflake (key-pair auth) ---------------------------------------------
# These GENAI_DBT_SNOWFLAKE_* vars are read directly by src/.../db/snowflake.py.
# The agent connects as the read-only AGENT_RO role; build/ingest/dbt use the developer role.
GENAI_DBT_SNOWFLAKE_ACCOUNT=
GENAI_DBT_SNOWFLAKE_USER_DEVELOPER=
GENAI_DBT_SNOWFLAKE_ROLE_DEVELOPER=
GENAI_DBT_SNOWFLAKE_WAREHOUSE_DEVELOPER=
GENAI_DBT_SNOWFLAKE_DATABASE_DEVELOPER=
GENAI_DBT_SNOWFLAKE_SCHEMA_DEVELOPER=
# Path to the PEM private key file (never commit the key itself).
GENAI_DBT_SNOWFLAKE_PRIVATE_KEY_PATH_DEVELOPER=
# Passphrase for the private key. Leave blank/"" if the key is unencrypted.
GENAI_DBT_SNOWFLAKE_PRIVATE_KEY_PASSPHRASE_DEVELOPER=

# --- Langfuse (tracing). Optional; tracing is a no-op if keys are unset. ----
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Agent guardrail tunables ----------------------------------------------
SQL_MAX_REPAIR_RETRIES=2
SQL_DEFAULT_ROW_LIMIT=1000
SQL_STATEMENT_TIMEOUT_MS=5000
