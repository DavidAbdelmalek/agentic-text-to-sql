# dbt
dbt/target/*
# catalog.json IS committed as a pinned schema snapshot so the semantic-layer drift gate
# (generate_semantic_layer.py --check) can run offline in CI. Regenerate with
# `dbt compile --write-catalog` when the warehouse schema changes.
!dbt/target/catalog.json
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml
# dbt/profiles.yml IS committed — it reads only env vars (no secrets).

